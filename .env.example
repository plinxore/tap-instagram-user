# tap-instagram-user / target-postgres configuration
# Copy this file to .env and fill in your actual values.
# Never commit the real .env file (already in .gitignore).

# Required: Meta Long-Lived Token (professional Instagram account)
TAP_INSTAGRAM_USER_ACCESS_TOKEN=your_meta_long_lived_token_here

# Required: the professional Instagram account ID (account-specific)
TAP_INSTAGRAM_USER_IG_USER_ID=your_ig_user_id_here

# Target Postgres connection (deployment-specific)
TARGET_POSTGRES_HOST=localhost
TARGET_POSTGRES_PORT=5432
TARGET_POSTGRES_USER=your_postgres_user_here
TARGET_POSTGRES_PASSWORD=your_postgres_password_here
TARGET_POSTGRES_DBNAME=your_postgres_database_here
TARGET_POSTGRES_DEFAULT_TARGET_SCHEMA=public
