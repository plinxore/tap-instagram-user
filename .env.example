# tap-instagram-user / target-postgres configuration
# Copy this file to .env and fill in your actual values.
# Never commit the real .env file (already in .gitignore).

# Required: Meta Long-Lived Token (professional Instagram account)
TAP_INSTAGRAM_USER_ACCESS_TOKEN=your_meta_long_lived_token_here

# Required: connection password for the target Postgres database
TARGET_POSTGRES_PASSWORD=your_postgres_password_here
